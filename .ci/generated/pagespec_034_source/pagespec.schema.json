      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "text"
        },
        "fallback": {
          "type": "string",
          "maxLength": 2000
        },
        "text": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S",
              "maxLength": 200000
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S",
                "maxLength": 5000
              },
              "minItems": 1,
              "maxItems": 2000
