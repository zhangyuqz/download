{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.invalid/pagespec/v1/schema.json",
  "title": "PageSpec v1 canonical schema (closed, no HTML/CSS/JavaScript escape hatch)",
  "description": "Strict producer contract. Tolerant aliases and repair forms are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "blocks"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "profile": {
      "const": "catalog-verification"
    },
    "doc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 1000
        },
        "filename": {
          "type": "string",
          "maxLength": 240
        },
        "theme": {
          "enum": [
            "dark",
            "light"
          ]
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{3}(?:[0-9a-fA-F]{3})?$"
        },
        "toc": {
          "type": "boolean"
        },
        "header": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string",
              "maxLength": 1000
            },
            "subtitle": {
              "type": "string",
              "maxLength": 2000
            },
            "badges": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S",
                "maxLength": 5000
              },
              "maxItems": 100
            }
          }
        },
        "footer": {
          "type": "string",
          "maxLength": 10000
        }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/block"
      },
      "minItems": 1,
      "maxItems": 800
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "blocks": {
            "contains": {
              "$ref": "#/definitions/catalog_demo"
            }
          }
        },
        "required": [
          "blocks"
        ]
      },
      "then": {
        "required": [
          "profile"
        ],
        "properties": {
          "profile": {
            "const": "catalog-verification"
          },
          "blocks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": {
              "$ref": "#/definitions/catalog_demo"
            }
          }
        }
      },
      "else": {
        "not": {
          "required": [
            "profile"
          ]
        }
      }
    }
  ],
  "definitions": {
    "heading": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "heading"
        },
        "fallback": {
          "type": "string",
          "maxLength": 2000
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "maxLength": 200000
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        }
      },
      "required": [
        "type",
        "text"
      ]
    },
    "text": {
